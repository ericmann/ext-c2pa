{
    "name": "ericmann/ext-c2pa",
    "description": "PHP 8.3+ native C2PA Content Credentials: read/validate manifests and sign Media Library images incl. derivatives.",
    "type": "php-ext",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/ericmann/ext-c2pa",
    "support": {
        "docs": "https://c2pa.eamann.com",
        "issues": "https://github.com/ericmann/ext-c2pa/issues",
        "source": "https://github.com/ericmann/ext-c2pa"
    },
    "authors": [
        {
            "name": "Eric Mann",
            "homepage": "https://eamann.com",
            "role": "Developer"
        },
        {
            "name": "Automattic, Inc.",
            "homepage": "https://automattic.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "php-ext": {
        "extension-name": "c2pa",
        "priority": 30,
        "support-zts": true,
        "support-nts": true,
        "os-families-exclude": [
            "windows"
        ],
        "download-url-method": [
            "pre-packaged-binary"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
